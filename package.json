{
  "name": "kessler-vscode",
  "displayName": "Kessler",
  "description": "Intelligently find and safely clean build artifacts and caches",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "kessler.showLaunchpad",
        "title": "Kessler: Clean Orbital Debris"
      },
      {
        "command": "kessler.rescan",
        "title": "Kessler: Rescan Workspace"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.1.3",
    "esbuild": "^0.18.0"
  }
}
